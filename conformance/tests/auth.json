[
  {
    "name": "Bearer token injected in Authorization header",
    "description": "Verifies that the SDK injects a bearer token as an Authorization header on every request",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "mockResponses": [
      {"status": 200, "body": []}
    ],
    "assertions": [
      {"type": "headerPresent", "path": "Authorization"},
      {"type": "noError"}
    ],
    "tags": ["auth", "bearer-token"]
  },
  {
    "name": "User-Agent header includes SDK identifier",
    "description": "Verifies that requests include a User-Agent header identifying the SDK and version",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "mockResponses": [
      {"status": 200, "body": []}
    ],
    "assertions": [
      {"type": "headerPresent", "path": "User-Agent"},
      {"type": "noError"}
    ],
    "tags": ["auth", "user-agent"]
  },
  {
    "name": "Bearer token value matches configured token",
    "description": "Verifies that the Authorization header contains the exact Bearer token value configured on the client (3A.3)",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "mockResponses": [
      {"status": 200, "body": []}
    ],
    "assertions": [
      {"type": "headerInjected", "path": "Authorization", "expected": "Bearer conformance-test-token"},
      {"type": "noError"}
    ],
    "tags": ["auth", "bearer-token", "header-value"]
  },
  {
    "name": "Content-Type set to application/json on POST",
    "description": "Verifies that POST requests include Content-Type: application/json header",
    "operation": "CreateProject",
    "method": "POST",
    "path": "/projects.json",
    "requestBody": {"name": "Header Test Project"},
    "mockResponses": [
      {"status": 201, "body": {"id": 99999, "name": "Header Test Project", "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "url": "https://3.basecampapi.com/999/projects/99999.json", "app_url": "https://3.basecamp.com/999/projects/99999"}}
    ],
    "assertions": [
      {"type": "headerInjected", "path": "Content-Type", "expected": "application/json"},
      {"type": "noError"}
    ],
    "tags": ["auth", "headers", "content-type"]
  }
]
