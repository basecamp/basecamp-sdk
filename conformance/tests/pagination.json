  {
    "name": "maxItems caps results across pages",
    "description": "Verifies that maxItems option caps the total items returned, stopping pagination early when enough items are collected (2C.4, 2C.6)",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "configOverrides": {
      "maxItems": 3
    },
    "mockResponses": [
