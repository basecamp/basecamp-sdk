[
  {
    "name": "List operation returns first page with Link header",
    "description": "Verifies that list operations return first page and expose Link header for pagination",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "Link": "</projects.json?page=2>; rel=\"next\"",
          "X-Total-Count": "75"
        },
        "body": {"projects": [
          {"id": 1, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 1", "url": "https://3.basecampapi.com/999/projects/1.json", "app_url": "https://3.basecamp.com/999/projects/1"},
          {"id": 2, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 2", "url": "https://3.basecampapi.com/999/projects/2.json", "app_url": "https://3.basecamp.com/999/projects/2"}
        ]}
      }
    ],
    "assertions": [
      {"type": "requestCount", "expected": 1},
      {"type": "statusCode", "expected": 200},
      {"type": "noError"}
    ],
    "tags": ["pagination", "link-header"]
  },
  {
    "name": "Total count header is accessible",
    "description": "Verifies that X-Total-Count header is parsed and accessible",
    "operation": "ListTodos",
    "method": "GET",
    "path": "/todolists/{todolistId}/todos.json",
    "pathParams": {"todolistId": 67890},
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "X-Total-Count": "42"
        },
        "body": {"todos": []}
      }
    ],
    "assertions": [
      {"type": "responseMeta", "path": "totalCount", "expected": 42},
      {"type": "noError"}
    ],
    "tags": ["pagination", "total-count"]
  },
  {
    "name": "Auto-pagination follows Link headers across multiple pages",
    "description": "Verifies that the SDK automatically follows Link rel=next headers to fetch all pages (2C.1, 2C.3)",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "Link": "</projects.json?page=2>; rel=\"next\""
        },
        "body": [
          {"id": 1, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 1", "url": "https://3.basecampapi.com/999/projects/1.json", "app_url": "https://3.basecamp.com/999/projects/1"},
          {"id": 2, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 2", "url": "https://3.basecampapi.com/999/projects/2.json", "app_url": "https://3.basecamp.com/999/projects/2"}
        ]
      },
      {
        "status": 200,
        "headers": {
          "Link": "</projects.json?page=3>; rel=\"next\""
        },
        "body": [
          {"id": 3, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 3", "url": "https://3.basecampapi.com/999/projects/3.json", "app_url": "https://3.basecamp.com/999/projects/3"},
          {"id": 4, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 4", "url": "https://3.basecampapi.com/999/projects/4.json", "app_url": "https://3.basecamp.com/999/projects/4"}
        ]
      },
      {
        "status": 200,
        "body": [
          {"id": 5, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 5", "url": "https://3.basecampapi.com/999/projects/5.json", "app_url": "https://3.basecamp.com/999/projects/5"}
        ]
      }
    ],
    "assertions": [
      {"type": "requestCount", "expected": 3},
      {"type": "noError"}
    ],
    "tags": ["pagination", "auto-follow"]
  },
  {
    "name": "Pagination stops at maxPages safety cap",
    "description": "Verifies that pagination stops after maxPages even when more pages are available (2C.3, 2C.6)",
    "operation": "ListProjects",
    "method": "GET",
    "path": "/projects.json",
    "configOverrides": {
      "maxPages": 2
    },
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "Link": "</projects.json?page=2>; rel=\"next\""
        },
        "body": [
          {"id": 1, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 1", "url": "https://3.basecampapi.com/999/projects/1.json", "app_url": "https://3.basecamp.com/999/projects/1"},
          {"id": 2, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 2", "url": "https://3.basecampapi.com/999/projects/2.json", "app_url": "https://3.basecamp.com/999/projects/2"}
        ]
      },
      {
        "status": 200,
        "headers": {
          "Link": "</projects.json?page=3>; rel=\"next\""
        },
        "body": [
          {"id": 3, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 3", "url": "https://3.basecampapi.com/999/projects/3.json", "app_url": "https://3.basecamp.com/999/projects/3"},
          {"id": 4, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 4", "url": "https://3.basecampapi.com/999/projects/4.json", "app_url": "https://3.basecamp.com/999/projects/4"}
        ]
      },
      {
        "status": 200,
        "body": [
          {"id": 5, "status": "active", "created_at": "2025-01-01T00:00:00Z", "updated_at": "2025-01-01T00:00:00Z", "name": "Project 5", "url": "https://3.basecampapi.com/999/projects/5.json", "app_url": "https://3.basecamp.com/999/projects/5"}
        ]
      }
    ],
    "assertions": [
      {"type": "requestCount", "expected": 2},
      {"type": "noError"},
      {"type": "responseMeta", "path": "truncated", "expected": true}
    ],
    "tags": ["pagination", "safety-cap"]
  },
