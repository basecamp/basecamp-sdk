{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API Gap Allowlist",
  "description": "Schema for spec/api-gaps/allowlist.yml — routes the detector classifies as not requiring a dedicated registry entry.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "not_api_resource": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason", "classified"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" },
          "classified": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
        }
      }
    },
    "absorbed_under_other_brief": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "covers_under", "reason", "classified"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "covers_under": { "type": "string", "description": "Brief identifier (gap field) that covers this route." },
          "reason": { "type": "string" },
          "classified": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
        }
      }
    }
  }
}
